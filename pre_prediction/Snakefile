import os, glob

configfile: "config.yaml"


# Detect GWAS dirs
gwas_paths = [
    os.path.join(config["gwas_root"], "GWAS_NAME"),        # ldl


]
    
#gwas_paths = glob.glob(os.path.join(config["gwas_root"], "PD*"))
gwas_dirs = [d for d in gwas_paths if os.path.isfile(os.path.join(d, config["gwas_filename"]))]
gwas_names = [os.path.basename(d) for d in gwas_dirs]

print(f"Detected GWAS: {gwas_names}")

# ---------------------------
# Final goal
# ---------------------------
rule all:
    input:
        expand(os.path.join(config["results_root"], "{gwas}/clumping_and_vcfs_outputs/main_gwas_snps_correct_ref_final.vcf"),
               gwas=gwas_names),
        expand(os.path.join(config["results_root"], "{gwas}/vcfs_mock_datasets/mock_dataset{idx}/mock_dataset{idx}_snps_correct_ref_final.vcf"),
               gwas=gwas_names,
               idx=range(1, config["n_mock_datasets"]+1))

# ---------------------------
# Rules
# ---------------------------

rule pre_clumping:
    input:
        gwas=lambda wc: os.path.join(config["gwas_root"], wc.gwas, config["gwas_filename"]),
        pop_panel=config["pop_panel"],
        kg_bed=config["kg_bfile"] + ".bed",
        kg_bim=config["kg_bfile"] + ".bim", 
        kg_fam=config["kg_bfile"] + ".fam", 
        
    output:
        bed=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/{gwas}_FILTERED_1kg/ds.bed"),
        bim=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/{gwas}_FILTERED_1kg/ds.bim"),
        fam=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/{gwas}_FILTERED_1kg/ds.fam"),
        gwas_for_clumping=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/gwas_for_clumping.txt")
    params:
        kg_bfile=config["kg_bfile"],  # Pass prefix to shell script
        output_prefix=lambda wc: os.path.join(config["results_root"], wc.gwas, f"pre_clumping_and_ld/{wc.gwas}_FILTERED_1kg/ds"),
        gnomad_file = config["gnomad_file"]
    shell:
        """
        bash gen_pre_clumping.sh \
            -g {input.gwas} \
            -p {input.pop_panel} \
            -k {params.kg_bfile} \
            -b {config[results_root]}/{wildcards.gwas} \
            -n {wildcards.gwas} \
            -m {params.gnomad_file}
        """

rule main_gwas_to_vcf:
    input:
        bed=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/{gwas}_FILTERED_1kg/ds.bed"),
        bim=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/{gwas}_FILTERED_1kg/ds.bim"),
        fam=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/{gwas}_FILTERED_1kg/ds.fam"),
        gwas_for_clumping=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/gwas_for_clumping.txt"),
    output:
        vcf=os.path.join(config["results_root"], "{gwas}/clumping_and_vcfs_outputs/main_gwas_snps_correct_ref_final.vcf"),
        # Add other expected outputs from this rule
        clumping_dir=directory(os.path.join(config["results_root"], "{gwas}/clumping_and_vcfs_outputs"))
    params:
        bfile_prefix=lambda wc: os.path.join(config["results_root"], wc.gwas, f"pre_clumping_and_ld/{wc.gwas}_FILTERED_1kg/ds"),
        base_dir=lambda wc: os.path.join(config["results_root"], wc.gwas),
        pvalue_threshold=config["pvalue_threshold"],
        ref_fasta=config["ref_fasta"]

    shell:
        """
        bash main_gwas_to_vcf_blacklist_local_bcf.sh \
            -n {wildcards.gwas} \
            -b {params.base_dir} \
            -p {params.pvalue_threshold} \
            -f {params.ref_fasta}
        """

rule sample_null_blocks:
    input:
        clumping_dir=os.path.join(config["results_root"], "{gwas}/clumping_and_vcfs_outputs"),
        bed=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/{gwas}_FILTERED_1kg/ds.bed"),
        bim=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/{gwas}_FILTERED_1kg/ds.bim"),
        fam=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/{gwas}_FILTERED_1kg/ds.fam")
    output:
        mock_dir=directory(os.path.join(config["results_root"], "{gwas}/mock_datasets")),
        mock_files=expand(
            os.path.join(config["results_root"], "{{gwas}}/mock_datasets/mock_dataset{idx}.tsv"),
            idx=range(1, config["n_mock_datasets"]+1)
        )
    params:
        n_mock=config["n_mock_datasets"],
        base_dir=lambda wc: os.path.join(config["results_root"], wc.gwas)
    resources:
        mem_mb=50000,  # For scheduling only
        sample_null_blocks_concurrent=1  # Only 1 at a time!
    shell:
        """
        python3 sample_null_blocks.py {params.base_dir} \
            --n_mock_datasets {params.n_mock} --use_pickles
        """


rule mock_to_vcf:
    input:
        bed=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/{gwas}_FILTERED_1kg/ds.bed"),
        bim=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/{gwas}_FILTERED_1kg/ds.bim"),
        fam=os.path.join(config["results_root"], "{gwas}/pre_clumping_and_ld/{gwas}_FILTERED_1kg/ds.fam"),
        mock_dir=os.path.join(config["results_root"], "{gwas}/mock_datasets"),
        specific_mock=os.path.join(config["results_root"], "{gwas}/mock_datasets/mock_dataset{idx}.tsv")
    output:
        vcf=os.path.join(
            config["results_root"],
            "{gwas}",
            "vcfs_mock_datasets/mock_dataset{idx}/mock_dataset{idx}_snps_correct_ref_final.vcf"
        )
    params:
        kg_bfile_prefix=lambda wc: os.path.join(config["results_root"], wc.gwas, f"pre_clumping_and_ld/{wc.gwas}_FILTERED_1kg/ds"),
        base_dir=lambda wc: os.path.join(config["results_root"], wc.gwas),
        ref_fasta=config["ref_fasta"]

    shell:
        """
        bash mock_dataset_to_vcf_single_local_bcf.sh \
            -k {params.kg_bfile_prefix} \
            -b {params.base_dir} \
            -i {wildcards.idx} \
            -f {params.ref_fasta}

        """